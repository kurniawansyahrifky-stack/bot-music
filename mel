@app.on_message(filters.group & ~filters.service, group=-2)
async def antibroadcast_main(_, message: Message):
    try:
        if not message or not message.from_user:
            return

        chat_id = message.chat.id
        user_id = message.from_user.id

        # DEBUG
        print(f"[ANTIBC] New message from {user_id} in {chat_id}")

        # antibc harus aktif
        enabled = await get_antibc(chat_id)
        print(f"[ANTIBC] Enabled: {enabled}")
        if not enabled:
            return

        # cek ankes aktif
        if not await ankes_active(chat_id):
            print("[ANTIBC] Ankes inactive")
            return

        # skip admin / owner / whitelist
        admin = await is_admin(chat_id, user_id)
        print(f"[ANTIBC] Is admin: {admin}")
        if admin:
            return

        # =====================================================
        # AMBIL SEMUA TEKS:
        # - pesan
        # - caption
        # - first name
        # - last name
        # - username
        # - bio/about Telegram
        # =====================================================
        text_parts = []

        if message.text:
            text_parts.append(message.text)

        if message.caption:
            text_parts.append(message.caption)

        if message.from_user.first_name:
            text_parts.append(message.from_user.first_name)

        if message.from_user.last_name:
            text_parts.append(message.from_user.last_name)

        if message.from_user.username:
            text_parts.append(message.from_user.username)

        # Ambil bio Telegram user
        try:
            full_user = await app.get_users(user_id)

            if getattr(full_user, "bio", None):
                text_parts.append(full_user.bio)

            elif getattr(full_user, "about", None):
                text_parts.append(full_user.about)

        except Exception:
            pass

        # Gabungkan semua text
        text_raw = "\n".join(
            str(x) for x in text_parts if x
        ).strip()

        print(f"[ANTIBC] Full text: {text_raw}")

        # Jika tidak ada text dan bukan forward
        if not text_raw and not message.forward_date:
            return

        compact = compact_text(text_raw)

        if text_raw and len(compact) < 3:
            return

        now = time.time()
        user_key = str(user_id)

        # =====================================================
        # SCORE DETECTION
        # =====================================================
        score = suspicious_score(text_raw)

        if message.forward_date:
            score += 3

        print(f"[ANTIBC] Score: {score}")

        # LANGSUNG HAPUS JIKA SCORE >= SCORE_THRESHOLD
        if score >= SCORE_THRESHOLD:
            print("[ANTIBC] DELETE BY SCORE")
            await punish_user(
                message,
                f"Score Detection ({score})"
            )
            return

        # =====================================================
        # AI DETECTION (Mailyan)
        # =====================================================
        if score >= AI_MIN_SCORE:
            print("[ANTIBC] Checking Mailyan AI...")

            if await mailyan_detect(text_raw):
                print("[ANTIBC] DELETE BY AI")
                await punish_user(
                    message,
                    f"Mailyan AI Detection ({score})"
                )
                return

        # =====================================================
        # CACHE CHECKS
        # =====================================================
        async with LOCKS[user_key]:

            # Exact repeat
            cache = USER_MESSAGE_CACHE[user_key]
            cache.append({
                "text": compact,
                "time": now,
                "chat": chat_id,
            })

            same_count = sum(
                1
                for x in cache
                if x["text"] == compact
                and now - x["time"] <= REPEAT_WINDOW
            )

            if same_count >= REPEAT_LIMIT:
                print("[ANTIBC] DELETE BY REPEAT")
                await punish_user(
                    message,
                    "Repeated broadcast"
                )
                return

            # Similar spam
            similar_count = 0

            for x in cache:
                if now - x["time"] > SIMILAR_WINDOW:
                    continue

                if similarity(x["text"], compact) >= 0.80:
                    similar_count += 1

            if similar_count >= SIMILAR_LIMIT:
                print("[ANTIBC] DELETE BY SIMILAR")
                await punish_user(
                    message,
                    "Similar broadcast spam"
                )
                return

            # Cross-group broadcast
            cross = USER_CROSS_CACHE[user_key]
            cross.append({
                "text": compact,
                "chat": chat_id,
                "time": now,
            })

            groups = set()

            for x in cross:
                if now - x["time"] > CROSS_GROUP_WINDOW:
                    continue

                if similarity(x["text"], compact) >= 0.80:
                    groups.add(x["chat"])

            if len(groups) >= CROSS_GROUP_LIMIT:
                print("[ANTIBC] DELETE BY CROSS GROUP")
                await punish_user(
                    message,
                    "Cross-group broadcast"
                )
                return

            # Forward flood
            if message.forward_date:
                fw = USER_FORWARD_CACHE[user_key]
                fw.append(now)

                recent_fw = sum(
                    1
                    for ts in fw
                    if now - ts <= FORWARD_WINDOW
                )

                if recent_fw >= FORWARD_LIMIT:
                    print("[ANTIBC] DELETE BY FORWARD FLOOD")
                    await punish_user(
                        message,
                        "Forward flood"
                    )
                    return

            # Duplicate in same group
            last_key = str(chat_id)

            if LAST_CHAT_MESSAGE.get(last_key) == compact:
                print("[ANTIBC] DELETE BY DUPLICATE")
                await punish_user(
                    message,
                    "Duplicate chat spam"
                )
                return

            LAST_CHAT_MESSAGE[last_key] = compact

    except Exception as e:
        print(f"ANTIBC ERROR: {e}")
