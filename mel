async def punish_user(message: Message, reason: str):
    try:
        await message.delete()
    except Exception:
        pass

    try:
        warn = await app.send_message(
            message.chat.id,
            f"⚠️ Spam terdeteksi dan dihapus.\nReason: {reason}"
        )
        await asyncio.sleep(4)
        await warn.delete()
    except Exception:
        pass


