async def is_whitelisted(user_id: int) -> bool:
    if user_id == OWNER_ID:
        return True

    if user_id in SUDO_USERS:
        return True

    return False


# =========================================================
# ADMIN CHECK
# =========================================================

async def is_admin(chat_id: int, user_id: int) -> bool:
    if await is_whitelisted(user_id):
        return True

    try:
        member = await app.get_chat_member(chat_id, user_id)
        return member.status in (
            ChatMemberStatus.OWNER,
            ChatMemberStatus.ADMINISTRATOR,
        )
    except Exception:
        return False


# =========================================================
# SCORE DETECTION
# =========================================================

def suspicious_score(text: str) -> int:
    if not text:
        return 0

    score = 0
    normalized = normalize_text(text)
    compact = compact_text(text)

    # ==========================================
    # KEYWORD DASAR
    # ==========================================
    hits = 0
    for kw in BAD_KEYWORDS:
        if compact_text(kw) in compact:
            hits += 1

    score += hits

    # ==========================================
    # REGEX PATTERNS
    # ==========================================
    for pattern in REGEX_PATTERNS:
        if re.search(pattern, normalized):
            score += 1

    # ==========================================
    # FRASE SEKSUAL TERSELUBUNG
    # ==========================================
    sexual_phrases = [
        "byoh",
        "biyoh",
        "dibiyoh",
        "dibiyohh",
        "di biyoh",
        "ke byoh",
        "kebiyoh",
        "kebyoh",
        "dbyo",
        "dbyoh",
        "dbiyoh",
        "omegg",
        "callsex",
        "ometv",
        "crott",
        "cro00t",
        "crot",
        "sampe crot",
        "sampai crot",
        "emut",
        "emutt",
        "di emut",
        "mainin",
        "maininn",
        "di mainin",
        "manjain kamu",
        "liatin ya",
        "liatin yuk",
        "liatin yug",
        "liatin",
        "pacaran yuk",
        "pacaran yug",
        "ngocok",
        "coli",
        "horny",
        "sange",
    ]

    for phrase in sexual_phrases:
        if compact_text(phrase) in compact:
            score += 2

    # ==========================================
    # KOMBINASI KATA MENCURIGAKAN
    # ==========================================
    combo_words = [
        "yuk",
        "yug",
        "hehe",
        "liatin",
        "manjain",
        "pacaran",
        "omegg",
        "byoh",
        "biyoh",
        "dbyo",
        "dbyoh",
        "crot",
        "emut",
        "mainin",
    ]

    combo_count = 0
    for word in combo_words:
        if compact_text(word) in compact:
            combo_count += 1

    if combo_count >= 2:
        score += 3

    # ==========================================
    # LINK
    # ==========================================
    if re.search(r"(https?://|t\.me/|telegram\.me|wa\.me)", text.lower()):
        score += 2

    # ==========================================
    # USERNAME / MENTION
    # ==========================================
    if re.search(r"@\w{4,}", text):
        score += 1

    # ==========================================
    # PESAN PANJANG + KEYWORD
    # ==========================================
    if len(compact) > 50 and score >= 1:
        score += 1

    # ==========================================
    # DEBUG
    # ==========================================
    print(f"[ANTIBC] suspicious_score => {score}")

    return score



# =========================================================
# AI DETECTION (MAILYAN)
