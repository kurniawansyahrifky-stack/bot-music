async def mailyan_detect(text: str) -> bool:
    if not MAILYAN_API_KEY or not text:
        return False

    payload = {
        "model": "gpt-4.1-mini",
        "messages": [
            {
                "role": "system",
                "content": (
                    "Kamu adalah AI anti spam Telegram. "
                    "Jawab hanya 'SPAM' jika pesan mengandung "
                    "promosi, iklan, broadcast, seksual, konten dewasa, "
                    "ajakan DM, ajakan cek bio, atau penawaran media. "
                    "Jawab hanya 'HAM' jika pesan normal."
                )
            },
            {
                "role": "user",
                "content": text[:3000]
            }
        ],
        "temperature": 0,
        "max_tokens": 5
    }

    headers = {
        "Authorization": f"Bearer {MAILYAN_API_KEY}",
        "Content-Type": "application/json"
    }

    try:
        timeout = aiohttp.ClientTimeout(total=10)

        async with aiohttp.ClientSession(timeout=timeout) as session:
            async with session.post(
                MAILYAN_API_URL,
                headers=headers,
                json=payload
            ) as resp:
                if resp.status != 200:
                    return False

                data = await resp.json()

                result = (
                    data.get("choices", [{}])[0]
                    .get("message", {})
                    .get("content", "")
                    .strip()
                    .upper()
                )

                return "SPAM" in result

    except Exception:
        return False


