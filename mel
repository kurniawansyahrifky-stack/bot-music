@app.on_message(filters.command("antibc") & filters.group)
async def antibc_toggle(_, message: Message):
    if not message.from_user:
        return

    if not await is_admin(message.chat.id, message.from_user.id):
        return

    if len(message.command) < 2:
        return await message.reply_text(
            "Gunakan:\n/antibc on\n/antibc off"
        )

    arg = message.command[1].lower()

    if arg == "on":
        await set_antibc(message.chat.id, True)
        await message.reply_text("✅ AntiBroadcast aktif.")

    elif arg == "off":
        await set_antibc(message.chat.id, False)
        await message.reply_text("✅ AntiBroadcast nonaktif.")


