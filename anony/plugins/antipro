class SmartBroadcastDetector:
    """
    Detector tambahan berbasis heuristik.
    Fokus mendeteksi:
    - l33t text (v1p, b0c1l, m3d14)
    - huruf dipisah spasi/simbol
    - promo seksual / media
    - ajakan DM/PC
    - rasio angka & simbol tidak wajar
    """

    def __init__(self):
        self.core_keywords = [
            "vip",
            "v1p",
            "vvip",
            "premium",
            "murah",
            "promo",
            "media",
            "fresh",
            "bocil",
            "bokep",
            "onlyfans",
            "onlyf4ns",
            "omek",
            "vcs",
            "openbo",
            "openvcs",
            "horny",
            "sange",
            "rate",
            "pcaku",
            "dmaku",
            "chataku",
            "dibiyoh",
            "biyoh",
            "langsunggas",
            "fullvid",
            "fullvideo",
        ]

        self.regex_rules = [
            r"v[i1!|]p",
            r"m[u4]r[a4]h",
            r"b[o0]k[e3]p",
            r"b[o0]c[i1]l",
            r"o[mn]e[kx]",
            r"v[c(]s",
            r"onlyf[a4]ns?",
            r"pc\s*a[kq]u",
            r"dm\s*a[kq]u",
            r"chat\s*a[kq]u",
            r"langsung\s*gas",
            r"full\s*v[i1]d",
            r"fresh\s*m[e3]d[i1]a",
        ]

    def _compress(self, text: str) -> str:
        text = normalize_text(text)
        return compact_text(text)

    def analyze(self, text: str):
        score = 0
        reasons = []

        if not text:
            return 0, []

        raw = text
        lowered = raw.lower()
        compact = self._compress(raw)

        # =====================================
        # KEYWORD HIT
        # =====================================
        hits = 0
        for kw in self.core_keywords:
            token = self._compress(kw)
            if token in compact:
                hits += 1

        if hits >= 1:
            score += hits * 2
            reasons.append(f"keyword_hits={hits}")

        # =====================================
        # REGEX RULES
        # =====================================
        regex_hits = 0
        for pattern in self.regex_rules:
            if re.search(pattern, compact):
                regex_hits += 1

        if regex_hits:
            score += regex_hits * 3
            reasons.append(f"regex_hits={regex_hits}")

        # =====================================
        # DIGIT RATIO
        # =====================================
        if compact:
            digit_ratio = sum(c.isdigit() for c in raw) / max(len(raw), 1)
            if digit_ratio >= 0.10:
                score += 2
                reasons.append("digit_ratio")
            if digit_ratio >= 0.20:
                score += 3

        # =====================================
        # SYMBOL RATIO
        # =====================================
        symbol_count = len(re.findall(r"[^a-zA-Z0-9\s]", raw))
        if symbol_count >= 5:
            score += 1
            reasons.append("symbols")
        if symbol_count >= 10:
            score += 2

        # =====================================
        # REPETITIVE CHARS
        # =====================================
        if re.search(r"(.)\1{3,}", lowered):
            score += 2
            reasons.append("repeated_chars")

        # =====================================
        # URL
        # =====================================
        if re.search(r"(https?://|t\.me/|wa\.me)", lowered):
            score += 5
            reasons.append("url")

        # =====================================
        # TELEGRAM USERNAME
        # =====================================
        if re.search(r"@\w{4,}", raw):
            score += 2
            reasons.append("username")

        # =====================================
        # CONTACT CTA
        # =====================================
        cta_patterns = [
            "pc aku",
            "dm aku",
            "chat aku",
            "sini pc",
            "sini dm",
            "rate",
            "media",
            "cek bio",
        ]

        for cta in cta_patterns:
            if self._compress(cta) in compact:
                score += 2
                reasons.append(f"cta:{cta}")

        # =====================================
        # FINAL BOOST
        # =====================================
        if score >= 8:
            score += 3
        if score >= 15:
            score += 5

        return score, reasons


