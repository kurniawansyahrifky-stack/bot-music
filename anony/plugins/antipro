def suspicious_score(text: str) -> int:
    """
    Detector super agresif.
    Menangkap:
    - l33t text (v1p, b0cil, m3dia)
    - huruf dipisah spasi/simbol
    - kata promosi
    - ajakan DM/PC
    - teks terlalu banyak keyword
    """

    if not text:
        return 0

    score = 0

    # -----------------------------------------
    # RAW
    # -----------------------------------------
    raw = remove_invisible(text)
    lowered = raw.lower()

    # -----------------------------------------
    # NORMALIZED
    # -----------------------------------------
    normalized = normalize_text(raw)
    compact = compact_text(normalized)

    # -----------------------------------------
    # KEYWORDS SUPER LENGKAP
    # -----------------------------------------
    keywords = [
        # vip / media
        "vip", "v1p", "vvip", "premium",
        "media", "fresh", "new",

        # jualan
        "murah", "termurah", "promo", "promosi",
        "diskon", "best price", "ready", "stok",
        "available",

        # grup
        "join", "gc", "group", "grup",
        "admin", "owner", "reseller",

        # konten
        "asupan", "bokep", "onlyfans", "onlyf4ns",
        "of", "ngewe", "ngentot", "sange",
        "horny", "open bo", "open vcs",
        "vcs", "vcs murah", "omek",
        "live", "video call", "call sex",

        # ajakan
        "pc aku", "dm aku", "chat aku",
        "sini pc", "sini dm", "langsung gas",
        "klik link", "cek bio", "rate",

        # variasi umum
        "biyoh", "dibiyoh", "di biyoh",
        "full vid", "full video",
        "private", "private room",
    ]

    # -----------------------------------------
    # HITUNG KEYWORD DI NORMALIZED + COMPACT
    # -----------------------------------------
    for word in keywords:
        w = compact_text(normalize_text(word))

        if w in compact:
            score += 2

        elif word.lower() in lowered:
            score += 2

    # -----------------------------------------
    # REGEX PATTERNS
    # -----------------------------------------
    patterns = [
        r"v[i1!|]p",
        r"m[u4]r[a4]h",
        r"b[o0]k[e3]p",
        r"b[o0]c[i1]l",
        r"o[mn]e[kx]",
        r"v[c(]s",
        r"onlyf[a4]ns?",
        r"fresh",
        r"full\s*v[i1]d",
        r"pc\s*a[kq]u",
        r"dm\s*a[kq]u",
        r"chat\s*a[kq]u",
        r"sini\s*(pc|dm)",
        r"langsung\s*gas",
        r"klik\s*link",
        r"cari\s*(cwk|cwe)",
        r"join\s*(gc|group|grup)",
    ]

    for pattern in patterns:
        if re.search(pattern, compact):
            score += 3

    # -----------------------------------------
    # HURUF BERLEBIHAN
    # contoh: muraaaahhhh
    # -----------------------------------------
    if re.search(r"(.)\1{3,}", lowered):
        score += 2

    # -----------------------------------------
    # BANYAK ANGKA (l33t)
    # -----------------------------------------
    digit_count = sum(c.isdigit() for c in raw)
    if digit_count >= 3:
        score += 2

    if digit_count >= 6:
        score += 2

    # -----------------------------------------
    # BANYAK SIMBOL
    # -----------------------------------------
    symbol_count = len(re.findall(r"[^a-zA-Z0-9\s]", raw))
    if symbol_count >= 5:
        score += 1

    if symbol_count >= 10:
        score += 2

    # -----------------------------------------
    # URL / LINK
    # -----------------------------------------
    if re.search(r"(https?://|t\.me/|telegram\.me|wa\.me)", lowered):
        score += 5

    # -----------------------------------------
    # USERNAME TELEGRAM
    # -----------------------------------------
    if re.search(r"@\w{4,}", raw):
        score += 2

    # -----------------------------------------
    # AJAKAN KONTAK
    # -----------------------------------------
    contact_phrases = [
        "pc aku",
        "dm aku",
        "tmo",
        "kolcek",
        "sini",
        "becek",
        "cekin",
        "rate",
    ]

    for phrase in contact_phrases:
        if compact_text(normalize_text(phrase)) in compact:
            score += 2

    # -----------------------------------------
    # BANYAK KEYWORD SEKALIGUS
    # -----------------------------------------
    hit_count = 0
    for word in keywords:
        w = compact_text(normalize_text(word))
        if w in compact:
            hit_count += 1

    if hit_count >= 2:
        score += 3

    if hit_count >= 3:
        score += 5

    if hit_count >= 4:
        score += 7

    # -----------------------------------------
    # PANJANG PESAN PROMOSI
    # -----------------------------------------
    if len(compact) > 60 and hit_count >= 2:
        score += 3

    # -----------------------------------------
    # CONTOH KHUSUS DARI SCREENSHOT
    # -----------------------------------------
    ultra_patterns = [
        "v1p",
        "v1d",
        "fullvid",
        "onlyfans",
        "freshmedia",
        "bocilviral",
        "langsunggas",
        "dibiyoh",
        "pcaku",
        "dmaku",
        "omek",
        "murah",
    ]

    for token in ultra_patterns:
        if token in compact:
            score += 3

    # -----------------------------------------
    # FINAL BOOST
    # -----------------------------------------
    if score >= 5:
        score += 3

    if score >= 10:
        score += 5

    return score


