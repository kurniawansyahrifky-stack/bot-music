@app.on_message(filters.group & ~filters.service, group=-2)
async def antibroadcast_main(_, message: Message):
    try:
        # =====================================================
        # BASIC VALIDATION
        # =====================================================
        if not message:
            return

        if not message.from_user:
            return

        chat_id = message.chat.id
        user_id = message.from_user.id

        # =====================================================
        # FEATURE CHECK
        # =====================================================
        if not await get_antibc(chat_id):
            return

        if not await ankes_active(chat_id):
            return

        # skip owner / sudo / admin
        if await is_admin(chat_id, user_id):
            return

        # =====================================================
        # GET MESSAGE TEXT
        # =====================================================
        text_raw = (
            message.text
            or message.caption
            or ""
        )

        # media tanpa caption dan bukan forward
        if not text_raw and not message.forward_date:
            return

        # =====================================================
        # NORMALIZE TEXT
        # =====================================================
        text_raw = remove_invisible(text_raw)
        normalized = normalize_text(text_raw)
        compact = compact_text(normalized)

        if len(compact) < 3:
            return

        # waktu & key user
        now = time.time()
        key = str(user_id)

        # =====================================================
        # AI + KEYWORD DETECT
        # =====================================================
        score = suspicious_score(text_raw)

        smart_score, smart_reasons = smart_detector.analyze(
            text_raw
        )
        score += smart_score

        # hard token boost
        ultra_tokens = [
            "v1p",
            "vip",
            "vvip",
            "premium",
            "freshmedia",
            "freshm3dia",
            "fullvid",
            "fullvideo",
            "onlyfans",
            "onlyf4ns",
            "dibiyoh",
            "biyoh",
            "omek",
            "pcaku",
            "dmaku",
            "chataku",
            "murah",
            "bokep",
            "bocil",
            "viral",
            "rate",
            "openbo",
            "openvcs",
            "vcs",
        ]

        for token in ultra_tokens:
            if token in compact:
                score += 4

        # regex super agresif
        if re.search(
            r"(b[o0]c[i1]l|"
            r"m[e3]d[i1]a|"
            r"v[i1]r[a4]l|"
            r"v[i1]d|"
            r"onlyf[a4]ns|"
            r"v[i1]p|"
            r"m[u4]r[a4]h)",
            compact
        ):
            score += 6

        # kombinasi keyword
        keyword_combo = [
            "murah",
            "vip",
            "media",
            "fresh",
            "fullvid",
            "onlyfans",
            "dibiyoh",
            "pcaku",
            "dmaku",
            "omek",
        ]

        combo_hits = 0
        for kw in keyword_combo:
            if kw in compact:
                combo_hits += 1

        if combo_hits >= 2:
            score += 6

        if combo_hits >= 3:
            score += 10

        # URL / username tambahan
        if re.search(r"(https?://|t\.me/|wa\.me)", text_raw.lower()):
            score += 5

        if re.search(r"@\w{4,}", text_raw):
            score += 2

        # =====================================================
        # AUTO PUNISH BERDASARKAN SCORE
        # =====================================================
        if score >= 6:
            reason_text = f"AI Detection ({score})"

            if smart_reasons:
                reason_text += " | " + " | ".join(
                    smart_reasons[:5]
                )

            await punish_user(
                message,
                reason_text
            )
            return

        # =====================================================
        # LOCK PER USER
        # =====================================================
        async with ANTIBC_LOCK[key]:

            # =================================================
            # SAME EXACT MESSAGE
            # =================================================
            cache = BROADCAST_CACHE[key]
            cache.append({
                "text": compact,
                "time": now,
                "chat": chat_id,
            })

            same_count = sum(
                1
                for x in cache
                if (
                    x["text"] == compact
                    and now - x["time"] <= BC_REPEAT_TIME
                )
            )

            if same_count >= BC_REPEAT_LIMIT:
                await punish_user(
                    message,
                    "Repeated broadcast"
                )
                return

            # =================================================
            # SIMILAR MESSAGE
            # =================================================
            similar_count = 0

            for x in cache:
                if now - x["time"] > BC_SIMILAR_TIME:
                    continue

                if checker.is_similar(
                    x["text"],
                    compact
                ):
                    similar_count += 1

            if similar_count >= BC_SIMILAR_LIMIT:
                await punish_user(
                    message,
                    "Similar broadcast spam"
                )
                return

            # =================================================
            # CROSS GROUP BROADCAST
            # =================================================
            cross = CROSS_CHAT_CACHE[key]
            cross.append({
                "text": compact,
                "chat": chat_id,
                "time": now,
            })

            groups = set()

            for x in cross:
                if now - x["time"] > BC_REPEAT_TIME:
                    continue

                if checker.is_similar(
                    x["text"],
                    compact
                ):
                    groups.add(x["chat"])

            if len(groups) >= BC_CROSSCHAT_LIMIT:
                await punish_user(
                    message,
                    "Cross-group broadcast"
                )
                return

            # =================================================
            # FORWARD FLOOD
            # =================================================
            if message.forward_date:
                fw = FORWARD_CACHE[key]
                fw.append(now)

                recent = sum(
                    1
                    for x in fw
                    if now - x <= BC_FORWARD_TIME
                )

                if recent >= BC_FORWARD_LIMIT:
                    await punish_user(
                        message,
                        "Forward flood"
                    )
                    return

            # =================================================
            # DUPLICATE LAST MESSAGE IN SAME CHAT
            # =================================================
            if LAST_MESSAGE[chat_id] == compact:
                await punish_user(
                    message,
                    "Duplicate chat spam"
                )
                return

            LAST_MESSAGE[chat_id] = compact

    except Exception as e:
        print(f"ANTIBC ERROR: {e}")


