class AdvancedSimilarityChecker:
    def __init__(self, threshold=0.72):
        self.threshold = threshold

    def preprocess(self, text):
        return unidecode(text.lower())

    def levenshtein_similarity(self, s1, s2):
        if not levenshtein_distance:
            return difflib.SequenceMatcher(None, s1, s2).ratio()

        max_len = max(len(s1), len(s2))
        if max_len == 0:
            return 1.0

        return 1 - (levenshtein_distance(s1, s2) / max_len)

    def ngram_similarity(self, s1, s2, n=2):
        if not ngrams:
            return difflib.SequenceMatcher(None, s1, s2).ratio()

        s1_ngrams = set(ngrams(s1, n))
        s2_ngrams = set(ngrams(s2, n))

        union = len(s1_ngrams.union(s2_ngrams))
        if union == 0:
            return 0

        inter = len(s1_ngrams.intersection(s2_ngrams))
        return inter / union

    def phonetic_similarity(self, s1, s2):
        if not doublemetaphone:
            return 0

        return 1 if doublemetaphone(s1) == doublemetaphone(s2) else 0

    def calculate_similarity(self, text1, text2):
        text1 = self.preprocess(text1)
        text2 = self.preprocess(text2)

        lev = self.levenshtein_similarity(text1, text2)
        ng = self.ngram_similarity(text1, text2)
        ph = self.phonetic_similarity(text1, text2)

        return (0.5 * lev) + (0.3 * ng) + (0.2 * ph)

    def is_similar(self, text1, text2):
        return self.calculate_similarity(text1, text2) >= self.threshold


checker = AdvancedSimilarityChecker()


