async def set_antibc(chat_id, status: bool):
    await db.cache.update_one(
        {"_id": f"antibc_{chat_id}"},
        {"$set": {"status": status}},
        upsert=True
    )


async def get_antibc(chat_id) -> bool:
    data = await db.cache.find_one(
        {"_id": f"antibc_{chat_id}"}
    )
    if not data:
        return False
    return data.get("status", False)


# =========================================================
# ANKES CHECK
# =========================================================

async def ankes_active(chat_id):
    try:
        status = await db.is_ankes(chat_id)
        if not status:
            return False

        expired = await db.get_expired(chat_id)
        if not expired:
            return False

        if int(time.time()) > int(expired):
            await db.remove_ankes(chat_id)
            return False

        return True
    except:
        return False


# =========================================================
# ADMIN CHECK
# =========================================================

async def is_admin(chat_id, user_id):
    if user_id == OWNER:
        return True

    if user_id in SUDO:
        return True

    try:
        member = await app.get_chat_member(chat_id, user_id)
        return member.status in [
            ChatMemberStatus.ADMINISTRATOR,
            ChatMemberStatus.OWNER,
        ]
    except:
        return False


# =========================================================
# NOTIFICATION
# =========================================================

async def notification(chat_id, text, duration=4):
    try:
        msg = await app.send_message(
            chat_id,
            f"⚠️ {text}"
        )
        await asyncio.sleep(duration)
        try:
            await msg.delete()
        except:
            pass
    except:
        pass


# =========================================================
# PUNISH
# =========================================================

async def punish_user(message: Message, reason: str):
    chat_id = message.chat.id
    user_id = message.from_user.id

    try:
        await message.delete()
    except:
        pass

    try:
        await app.restrict_chat_member(
            chat_id,
            user_id,
            ChatPermissions()
        )
    except RPCError:
        pass

    await notification(
        chat_id,
        f"Broadcast terdeteksi.\nReason: {reason}"
    )


