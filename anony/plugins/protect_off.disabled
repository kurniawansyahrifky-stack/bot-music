@app.on_message(filters.command("addwhite") & filters.group)
async def addwhite(_, m: types.Message):
    if not await is_admin(m.from_user.id, m.chat.id):
        return

    if not await check_force_sub(m.from_user.id):
        return await m.reply("wajib join support channel dulu", reply_markup=join_button)

    if len(m.command) < 2:
        return await m.reply("/addwhite @username/id")

    target = m.command[1].replace("@", "")
    data = await get_chat(m.chat.id)

    if target not in data["whitelist"]:
        data["whitelist"].append(target)
        await save_chat(m.chat.id, data)

    await m.reply(f"whitelist added: {target}")


@app.on_message(filters.command("bl") & filters.group)
async def addblack(_, m: types.Message):
    if not await is_admin(m.from_user.id, m.chat.id):
        return

    if not await check_force_sub(m.from_user.id):
        return await m.reply("wajib join support channel dulu", reply_markup=join_button)

    if len(m.command) < 2:
        return await m.reply("/bl kata")

    kata = m.text.split(None, 1)[1].lower()
    data = await get_chat(m.chat.id)

    if kata not in data["blacklist"]:
        data["blacklist"].append(kata)
        await save_chat(m.chat.id, data)

    await m.reply(f"blacklist added: {kata}")


@app.on_message(filters.group & ~filters.service)
async def protect_watcher(_, m: types.Message):
    if not m.from_user:
        return

    if await is_admin(m.from_user.id, m.chat.id):
        return

    username = m.from_user.username or ""

    if await is_whitelist(m.chat.id, m.from_user.id, username):
        return

    data = await get_chat(m.chat.id)
    text = m.text or m.caption or ""
    norm = normalize_text(text)

    if forwarded_gcast_detect(m):
        with contextlib.suppress(Exception):
            await m.delete()
        return

    if m.from_user.id in new_join_watch:
        if time.time() - new_join_watch[m.from_user.id] <= 120:
            if suspicious_pattern(text):
                with contextlib.suppress(Exception):
                    await m.delete()
                return

    custom_bad = data["blacklist"] + GLOBAL_BADWORDS

    for bad in custom_bad:
        if bad in norm:
            with contextlib.suppress(Exception):
                await m.delete()
            return

    for bad in custom_bad:
        if similarity(bad, norm) >= 0.68:
            with contextlib.suppress(Exception):
                await m.delete()
            return

    if len(norm.split()) >= 8:
        score = 0

        promo_keys = [
            "ready","open","jastip","murmer","trusted","admin","stok","transaksi",
            "join","gc","ch","panel","nokos","payment","all","promo","murid"
        ]

        for k in promo_keys:
            if k in norm:
                score += 1

        if score >= 2:
            with contextlib.suppress(Exception):
                await m.delete()
            return

    if data["antispam"]:
        if spam_detector.detect_spam(m.from_user.id, m.chat.id, norm):
            with contextlib.suppress(Exception):
                await m.delete()
            return

    uid = str(m.from_user.id)
    now = time.time()

    if uid not in user_cache:
        user_cache[uid] = {"times": [], "texts": [], "media": []}

    user_cache[uid]["times"].append(now)
    user_cache[uid]["texts"].append(norm)
    user_cache[uid]["media"].append(bool(m.photo or m.video or m.document or m.animation or m.sticker))

    user_cache[uid]["times"] = [x for x in user_cache[uid]["times"] if now - x < 10]
    user_cache[uid]["texts"] = user_cache[uid]["texts"][-6:]
    user_cache[uid]["media"] = user_cache[uid]["media"][-6:]

    if data["antispam"]:
        if len(user_cache[uid]["times"]) >= 3:
            with contextlib.suppress(Exception):
                await m.delete()
            return

        if suspicious_pattern(text):
            with contextlib.suppress(Exception):
                await m.delete()
            return

        if user_cache[uid]["media"].count(True) >= 3:
            with contextlib.suppress(Exception):
                await m.delete()
            return

    if data["antibc"] and len(norm) > 5:
        for old in user_cache[uid]["texts"][:-1]:
            if similarity(old, norm) >= 0.72:
                with contextlib.suppress(Exception):
                    await m.delete()
                return

        if suspicious_pattern(text):
            with contextlib.suppress(Exception):
                await m.delete()
            return
